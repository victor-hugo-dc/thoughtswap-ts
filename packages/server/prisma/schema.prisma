generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  canvasId     String   @unique
  name         String
  email        String   @unique
  role         String   @default("STUDENT") // STUDENT, TEACHER, or ADMIN
  accessToken  String
  refreshToken String?
  
  consentGiven Boolean  @default(false)
  consentDate  DateTime?

  thoughts          Thought[]
  savedPrompts      SavedPrompt[]
  swapRequests      SwapRequest[]
  courseEnrollments CourseEnrollment[]
  teacherOf         Course[]  // Courses taught by this teacher

  @@map("users")
}

model SavedPrompt {
  id        String   @id @default(uuid())
  content   String
  type      String   @default("TEXT") // TEXT, MC, SCALE
  options   Json?    // Stores options for MC as an array of strings
  teacherId String
  teacher   User     @relation(fields: [teacherId], references: [id])
  createdAt DateTime @default(now())

  @@map("saved_prompts")
}

model Course {
  id           String   @id @default(uuid())
  canvasId     String   @unique  // Canvas course ID
  title        String
  semester     String   @default("Unknown")  // Term/semester name from Canvas
  teacherId    String?
  teacher      User?    @relation(fields: [teacherId], references: [id])
  isActive     Boolean  @default(false)  // Whether teacher has activated this class
  
  enrollments  CourseEnrollment[]
  sessions     Session[]

  @@map("courses")
}

model CourseEnrollment {
  id        String   @id @default(uuid())
  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrolledAt DateTime @default(now())

  @@unique([studentId, courseId])
  @@map("course_enrollments")
}

model Session {
  id              String      @id @default(uuid())
  courseId        String
  course          Course      @relation(fields: [courseId], references: [id])
  status          String      @default("ACTIVE") // ACTIVE, SWAPPING, COMPLETED
  maxSwapRequests Int         @default(1)        // Configurable limit for swap requests
  prompts         PromptUse[]
  swapRequests    SwapRequest[]
}

model SwapRequest {
  id        String   @id @default(uuid())
  studentId String
  student   User     @relation(fields: [studentId], references: [id])
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id])
  createdAt DateTime @default(now())

  @@map("swap_requests")
}

model PromptUse {
  id        String    @id @default(uuid())
  content   String
  type      String    @default("TEXT") // TEXT, MC, SCALE
  options   Json?
  sessionId String
  session   Session   @relation(fields: [sessionId], references: [id])
  thoughts  Thought[]
}

model Thought {
  id          String    @id @default(uuid())
  content     String
  
  authorId    String
  author      User      @relation(fields: [authorId], references: [id]) 

  assignedTo  String?   
  
  promptUseId String
  promptUse   PromptUse @relation(fields: [promptUseId], references: [id])
}

model Log {
  id        String   @id @default(uuid())
  event     String
  userId    String?
  payload   Json?
  createdAt DateTime @default(now())

  @@map("logs")
}